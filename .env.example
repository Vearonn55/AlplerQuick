# Copy to .env and fill in values. Never commit .env (it is gitignored).

# Telegram — @BotFather
TELEGRAM_BOT_TOKEN=

# Comma-separated numeric user IDs
ALLOWED_TELEGRAM_USER_IDS=

# WordPress site root (no trailing slash). Bot uses WP_BASE_URL + /wp-json/wp/v2/...
WP_BASE_URL=
WP_USERNAME=
WP_APPLICATION_PASSWORD=

# Catalogues page ID (numeric)
WP_PAGE_ID=

# Optional: catalogue JSON path (default: catalogues.json next to project root)
# CATALOGUES_CONFIG=catalogues.json

# Recommended on VPS: polling (no nginx / public URL for the bot)
BOT_MODE=polling

# --- Webhook only (ignore when using polling) ---
# WEBHOOK_BASE_URL=https://kurulum.alplerltd.com
# WEBHOOK_PATH=/telegram/webhook
# PORT=8080
# TELEGRAM_WEBHOOK_SECRET=
